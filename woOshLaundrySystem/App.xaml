<Application x:Class="woOshLaundrySystem.App" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" StartupUri="Views/LoginWindow.xaml">
  <Application.Resources>
    <Style TargetType="Button"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="10,6"/><Setter Property="Background" Value="#42BCE2"/><Setter Property="Foreground" Value="White"/><Setter Property="BorderThickness" Value="0"/></Style>
    <Style TargetType="TextBox"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="8"/></Style>
    <Style TargetType="PasswordBox"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="8"/></Style>
    <Style TargetType="ComboBox"><Setter Property="Margin" Value="4"/><Setter Property="Padding" Value="8"/></Style>
    <Style TargetType="DataGrid"><Setter Property="Margin" Value="4"/><Setter Property="AutoGenerateColumns" Value="True"/><Setter Property="IsReadOnly" Value="True"/></Style>
  </Application.Resources>
</Application>
