<Window x:Class="woOshLaundrySystem.Views.DashboardWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="woOsh Dashboard" Height="720" Width="1100" WindowStartupLocation="CenterScreen">
    <DockPanel>
        <StackPanel DockPanel.Dock="Left" Width="190" Background="#EAF7FB" Margin="0">
            <TextBlock Text="woOsh" FontSize="28" FontWeight="Bold" Foreground="#42BCE2" Margin="10,10,10,4"/>
            <TextBlock x:Name="WelcomeText" Text="Selamat datang" Margin="10,0,10,20"/>
            <Button Content="Dashboard" Click="Dashboard_Click" Margin="10,4"/>
            <Button Content="Pelanggan" Click="Customers_Click" Margin="10,4"/>
            <Button Content="Order Baru" Click="NewOrder_Click" Margin="10,4"/>
            <Button Content="Semua Order" Click="Orders_Click" Margin="10,4"/>
            <Button Content="Tambah Pelanggan" Click="AddCustomer_Click" Margin="10,4"/>
            <Button Content="Logout" Click="Logout_Click" Background="#777" Margin="10,40,10,4"/>
        </StackPanel>
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </DockPanel>
</Window>
